<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_hospital_patient_tree" model="ir.ui.view">
        <field name="name">hospital.patient.tree</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <tree export_xlsx="0">
                <field name="name"/>
                <field name="ref"/>
                <field name="appointment_count" sum="Total Appointment"/>
                <field name="age"/>
                <field name="gender"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_hospital_patient_form" model="ir.ui.view">
        <field name="name">hospital.patient.form</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <!-- Smart Buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_view_appointments" icon="fa-calendar">
                            <field string="Appointment" name="appointment_count" widget="statinfo"/>
                        </button>
                    </div>
                    <!-- Patient Image -->
                    <field name="image" widget="image" class="oe_avatar"/>
                    <!-- Patient Title -->
                    <div class="oe_title">
                        <div class="oe_edit_only">
                            <label for="name" string="Patient Name"/>
                        </div>

                        <h1>
                            <field name="name" nolabel="1"/>
                        </h1>
                    </div>
                    <group string="General Information">
                        <group>
                            <field name="ref"/>
                            <field name="date_of_birth"/>
                            <field name="age"/>
                            <field name="gender" widget="radio"/>
                        </group>

                        <group>
                            <field name="appointment_id"/>
                            <field name="appointment_count" invisible="1"/>
                            <field name="tag_ids"
                                   widget="many2many_tags"
                                   options="{'color_field': 'color'}"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <group string="Other Information">
                            <field name="marital_status"/>
                            <field name="partner_name"
                                   invisible="marital_status != 'married'"
                                   required="marital_status == 'married'"/>
                        </group>

                        <group string="Contact Information">
                            <field name="phone" widget="phone"/>
                            <field name="email" widget="email"/>
                            <field name="website" widget="url"/>
                        </group>
                    </group>
                    <group>
                        <group string="Emergency Contact">
                            <field name="emergency_contact_name"/>
                            <field name="emergency_contact_phone"/>
                        </group>
                    </group>
                </sheet>
                <!-- Chatter-->
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_hospital_patient_search" model="ir.ui.view">
        <field name="name">hospital.patient.search</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Patient Name" filter_domain="['|', ('name', 'ilike', self), ('ref', 'ilike', self)]"/>
                <field name="ref"/>
                <field name="age"/>
                <field name="gender"/>

                <separator/>

                <filter name="filter_archived" string="Archived" domain="[('active', '=', False)]"/>


                <searchpanel>
                    <field name="gender" icon="fa-users" select="multi" enable_counters="1"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <record id="action_hospital_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hospital.patient</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first patient!
            </p>
        </field>
    </record>

    <menuitem id="menu_patient"
              name="Patients"
              action="action_hospital_patient"
              parent="menu_patient_master"
              sequence="0"
    />

</odoo>
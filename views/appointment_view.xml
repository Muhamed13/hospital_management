<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="action_mark_as_done" model="ir.actions.server">
        <field name="name">Mark As Done</field>
        <field name="type">ir.actions.server</field>
        <field name="model_id" ref="model_hospital_appointment"/>
        <field name="binding_model_id" ref="model_hospital_appointment"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code"><![CDATA[    
        records.action_done()
        ]]>
<!--             records.filtered(lambda r: r.state == 'in_consultation').action_done()-->
<!--             records.action_done()-->
        </field>
    </record>

    <record id="view_hospital_appointment_activity" model="ir.ui.view">
        <field name="name">hospital.appointment.activity</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">

            <activity string="Appointments">
                <field name="patient_id"/>
                <field name="ref"/>
                <templates>
                    <div t-name="activity-box">
                        <img t-att-src="activity_image('hospital.patient', 'image', record.patient_id.raw_value)"
                             t-att-title="record.patient_id.raw_value" t-att-alt="record.patient_id.raw_value"/>
                    </div>
                    <div>
                        <field name="ref" display="full"/>
                    </div>
                </templates>
            </activity>
        </field>
    </record>

    <record id="view_hospital_appointment_calendar" model="ir.ui.view">
        <field name="name">hospital.appointment.calendar</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <calendar string="Appointments" date_start="booking_date" mode="month" date_delay="duration"
                      color="state">
                <field name="patient_id"/>
                <field name="state" filters="1"/>
            </calendar>
        </field>
    </record>

    <record id="view_hospital_appointment_tree" model="ir.ui.view">
        <field name="name">hospital.appointment.tree</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <tree decoration-success="state == 'done'" decoration-danger="state == 'cancel'" sample="1" multi_edit="1">
                <field name="doctor_id" widget="many2one_avatar_user"/>
                <field name="patient_id"/>
                <field name="appointment_time"/>
                <field name="booking_date" optional="1"/>
                <field name="activity_ids" widget="list_activity"/>
                <field name="ref" optional="1"/>
                <field name="gender" optional="1"/>
                <field name="state"
                       decoration-success="state == 'done'"
                       decoration-info="state == 'draft'"
                       decoration-danger="state == 'cancel'"
                       decoration-warning="state == 'in_consultation'"
                       widget="badge"/>
            </tree>
        </field>
    </record>

    <record id="view_hospital_appointment_form" model="ir.ui.view">
        <field name="name">hospital.appointment.form</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <form>
                <header>

                    <button name="action_in_consultation"
                            string="Start Consultation"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>

                    <button name="action_done"
                            string="Mark as Done"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'in_consultation'"/>

                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            class="btn-danger"
                            invisible="state not in ('draft', 'in_consultation')"/>
    
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,in_consultation,done,cancel"/>

                </header>

                <sheet>

                    <div class="oe_button_box" name="button_box">
                        <button name="action_share_whatsapp"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-whatsapp">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">WhatsApp</span>
                            </div>
                        </button>

                        <button name="%(action_appointment_report)d"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-print">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Print</span>
                            </div>
                        </button>
                    </div>

                    <div>
                        <h1>
                            <field name="ref" readonly="1"/>
                        </h1>
                        <h2>
                            <field name="patient_id"/>
                        </h2>
                    </div>
                    <group>
                     <group>
                         <field name="patient_ref" readonly="1"/>
                         <field name="doctor_id" widget="many2one_avatar_user"/>
                         <field name="gender"/>
                         <field name="operation_id"/>
                         <field name="duration"/>
                     </group>
                     <group>
                         <field name="booking_date" help="Date of booking"/>
                         <field name="appointment_time"/>
                         <field name="company_id" groups="base.group_multi_company"/>
                         <field name="currency_id" invisible="1"/>
                         <field name="hide_sales_price"  invisible="1"/>
                         <field name="priority" widget="priority"/>
                     </group>
                    </group>
                    <notebook>
                        <page string="Prescription" name="prescription">
                            <field name="prescription" placeholder="Enter your prescription"
                            options="{'collaborative': true, 'resizable': true}"/>
                        </page>
                        <page string="Pharmacy" name="pharmacy">
                            <field name="pharmacy_line_ids">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="price_unit" widget="monetary"
                                           options="{'currency_field': 'currency_id', 'fields_digits': True}"
                                           column_invisible="parent.hide_sales_price"/>
                                    <field name="qty"/>
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="price_subtotal"/>
                                </tree>
                                <form>
                                    <group>
                                        <field name="product_id"/>
                                        <field name="price_unit"
                                               column_invisible="parent.hide_sales_price"/>
                                        <field name="qty"/>
                                    </group>
                                </form>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="amount_total" widget="monetary"
                                       options="{'currency_field': 'currency_id'}" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <!-- Chatter-->
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_hospital_appointment_search" model="ir.ui.view">
        <field name="name">hospital.appointment.search</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <search>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="booking_date"/>
                <field name="state"/>

                <separator/>

                <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>

                <filter name="filter_in_consultation" string="In Consultation" domain="[('state', '=', 'in_consultation')]"/>

                <filter name="filter_done" string="Done" domain="[('state', '=', 'done')]"/>

                <filter name="filter_cancelled" string="Cancelled" domain="[('state', '=', 'cancel')]"/>
            </search>
        </field>
    </record>

    <record id="action_hospital_appointment" model="ir.actions.act_window">
        <field name="name">Appointments</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hospital.appointment</field>
        <field name="view_mode">tree,form,calendar,activity</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first appointment !
            </p>
        </field>
    </record>

    <menuitem id="menu_appointment"
              name="Appointments"
              action="action_hospital_appointment"
              parent="menu_appointment_master"
              sequence="10"
    />

</odoo>
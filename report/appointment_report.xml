<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Report Action -->
    <record id="action_appointment_report" model="ir.actions.report">
        <field name="name">Appointment Report</field>
        <field name="model">hospital.appointment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hospital_management.appointment_report_template</field>
        <field name="report_file">hospital_management.appointment_report_template</field>
        <field name="print_report_name">'Appointment - %s' % (object.ref)</field>
    </record>

    <!-- Report Template -->
    <template id="appointment_report_template">

        <t t-call="web.html_container">

            <t t-foreach="docs" t-as="doc">

                <t t-call="web.external_layout">

                    <style>

                        .page{
                            font-size:13px;
                            color:#333333;
                            font-family: Arial, Helvetica, sans-serif;
                        }

                        .report-header{
                            text-align:center;
                            margin:10px 0 30px 0;
                            padding-bottom:16px;
                            border-bottom:3px solid #1a7a6e;
                        }

                        .report-title{
                            font-size:26px;
                            font-weight:bold;
                            color:#1a4d47;
                            margin:0;
                            letter-spacing:0.5px;
                        }

                        .report-subtitle{
                            font-size:13px;
                            color:#888888;
                            margin-top:4px;
                        }

                        .status-badge{
                            display:inline-block;
                            padding:3px 14px;
                            border-radius:12px;
                            background:#e8f5f3;
                            color:#1a7a6e;
                            font-weight:bold;
                            font-size:12px;
                            margin-top:8px;
                            border:1px solid #1a7a6e;
                        }

                        .section-title{
                            font-size:15px;
                            color:#1a4d47;
                            font-weight:bold;
                            margin:0 0 10px 0;
                            padding-left:10px;
                            border-left:4px solid #1a7a6e;
                        }

                        .info-columns{
                            width:100%;
                            overflow:hidden;
                            margin-bottom:10px;
                        }

                        .info-col{
                            width:48%;
                            float:left;
                        }

                        .info-col + .info-col{
                            float:right;
                        }

                        .info-table{
                            width:100%;
                            border-collapse:collapse;
                            border:1px solid #e0e0e0;
                        }

                        .info-table tr:nth-child(even){
                            background:#f8f9fa;
                        }

                        .info-table th{
                            width:40%;
                            text-align:left;
                            background:#eef4f3;
                            color:#1a4d47;
                            padding:7px 10px;
                            border:1px solid #e0e0e0;
                            font-size:12px;
                        }

                        .info-table td{
                            padding:7px 10px;
                            border:1px solid #e0e0e0;
                            font-size:12px;
                        }

                        .prescription-box{
                            border:1px solid #e0e0e0;
                            border-radius:4px;
                            min-height:100px;
                            padding:12px;
                            background:#fbfbfb;
                            margin-bottom:10px;
                        }

                        .pharmacy-table{
                            width:100%;
                            border-collapse:collapse;
                            margin-top:5px;
                        }

                        .pharmacy-table th{
                            background:#1a7a6e;
                            color:white;
                            padding:8px 10px;
                            border:1px solid #1a7a6e;
                            font-size:12px;
                            text-align:left;
                        }

                        .pharmacy-table td{
                            border:1px solid #e0e0e0;
                            padding:7px 10px;
                            font-size:12px;
                        }

                        .pharmacy-table tbody tr:nth-child(even){
                            background:#f8f9fa;
                        }

                        .text-center{
                            text-align:center;
                        }

                        .text-end{
                            text-align:right;
                        }

                        .total-box{
                            width:280px;
                            float:right;
                            margin-top:12px;
                        }

                        .total-box table{
                            width:100%;
                            border-collapse:collapse;
                        }

                        .total-box th{
                            background:#1a4d47;
                            color:white;
                            padding:9px 12px;
                            border:1px solid #1a4d47;
                            font-size:13px;
                            text-align:left;
                        }

                        .total-box td{
                            padding:9px 12px;
                            border:1px solid #1a4d47;
                            font-size:14px;
                            font-weight:bold;
                            text-align:right;
                            color:#1a4d47;
                        }

                        .clearfix{
                            clear:both;
                        }

                    </style>

                    <div class="page">

                        <div class="report-header">
                            <h2 class="report-title">Appointment Report</h2>
                            <div class="report-subtitle">
                                Reference: <span t-field="doc.ref"/>
                            </div>
                            <div class="status-badge">
                                <span t-field="doc.state"/>
                            </div>
                        </div>

                        <div class="info-columns">

                            <div class="info-col">

                                <h4 class="section-title">Patient Information</h4>

                                <table class="info-table">

                                    <tr>
                                        <th>Reference</th>
                                        <td><span t-field="doc.ref"/></td>
                                    </tr>

                                    <tr>
                                        <th>Patient</th>
                                        <td><span t-field="doc.patient_id"/></td>
                                    </tr>

                                    <tr>
                                        <th>Patient Ref</th>
                                        <td><span t-field="doc.patient_ref"/></td>
                                    </tr>

                                    <tr>
                                        <th>Doctor</th>
                                        <td><span t-field="doc.doctor_id"/></td>
                                    </tr>

                                    <tr>
                                        <th>Gender</th>
                                        <td><span t-field="doc.gender"/></td>
                                    </tr>

                                </table>

                            </div>

                            <div class="info-col">

                                <h4 class="section-title">Appointment Details</h4>

                                <table class="info-table">

                                    <tr>
                                        <th>Booking Date</th>
                                        <td><span t-field="doc.booking_date"/></td>
                                    </tr>

                                    <tr>
                                        <th>Appointment Time</th>
                                        <td><span t-field="doc.appointment_time"/></td>
                                    </tr>

                                    <tr>
                                        <th>Operation</th>
                                        <td><span t-field="doc.operation_id"/></td>
                                    </tr>

                                    <tr>
                                        <th>Priority</th>
                                        <td><span t-field="doc.priority"/></td>
                                    </tr>

                                </table>

                            </div>

                        </div>

                        <div class="clearfix"/>

                        <h4 class="section-title" style="margin-top:20px;">Prescription</h4>

                        <div class="prescription-box">
                            <span t-field="doc.prescription"/>
                        </div>

                        <h4 class="section-title">Pharmacy</h4>

                        <table class="pharmacy-table">

                            <thead>

                                <tr>

                                    <th>Medicine</th>
                                    <th class="text-center">Qty</th>
                                    <th class="text-end">Unit Price</th>
                                    <th class="text-end">Subtotal</th>

                                </tr>

                            </thead>

                            <tbody>

                                <tr t-foreach="doc.pharmacy_line_ids" t-as="line">

                                    <td>
                                        <span t-field="line.product_id"/>
                                    </td>

                                    <td class="text-center">
                                        <span t-field="line.qty"/>
                                    </td>

                                    <td class="text-end">
                                        <span t-field="line.price_unit"/>
                                    </td>

                                    <td class="text-end">
                                        <span t-field="line.price_subtotal"/>
                                    </td>

                                </tr>

                            </tbody>

                        </table>

                        <div class="total-box">

                            <table>

                                <tr>
                                    <th>Total Amount</th>
                                    <td>
                                        <span t-field="doc.amount_total"/>
                                    </td>
                                </tr>

                            </table>
                        </div>

                        <div class="clearfix"/>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>